{
  "name": "edvance",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "seed:clusters": "tsx --env-file=.env scripts/seed-clusters.ts",
    "seed:taxonomy": "tsx --env-file=.env scripts/seed-taxonomy.ts",
    "mark:diagnostic": "tsx --env-file=.env scripts/mark-diagnostic.ts",
    "seed:screening-items": "tsx --env-file=.env scripts/seed-screening-items.ts",
    "seed:vera8": "tsx --env-file=.env scripts/seed_vera8.ts",
    "import:lambacher": "tsx --env-file=.env scripts/import/lambacher.ts",
    "generate:assets": "tsx --env-file=.env scripts/generate-assets.ts",
    "sim:screening": "tsx scripts/screening-sim.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.45.4",
    "@types/katex": "^0.16.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "i18next": "^26.2.0",
    "katex": "^0.16.45",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.7"
  }
